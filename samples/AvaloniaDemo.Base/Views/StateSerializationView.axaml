<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:paz="using:Avalonia.Controls.PanAndZoom"
             xmlns:vm="using:AvaloniaDemo.ViewModels"
             x:Class="AvaloniaDemo.Views.StateSerializationView"
             x:DataType="vm:StateSerializationViewModel">

  <Grid ColumnDefinitions="*,300">
    <!-- ZoomBorder -->
    <Border Grid.Column="0" Margin="12" BorderBrush="Gray" BorderThickness="1">
      <paz:ZoomBorder x:Name="ZoomBorder"
                      Stretch="None"
                      ZoomSpeed="1.2"
                      Background="SlateBlue"
                      ClipToBounds="True">
        <Canvas Width="500" Height="500" Background="LightGray">
          <TextBlock Canvas.Left="20" Canvas.Top="20" Text="State Serialization Demo" FontSize="24" FontWeight="Bold" />

          <TextBlock Canvas.Left="20" Canvas.Top="70" TextWrapping="Wrap" Width="460" FontSize="14">
            Pan and zoom to different positions, then export the state. You can restore it later using the Import button.
          </TextBlock>

          <Rectangle Fill="Red" Width="100" Height="100" Canvas.Left="50" Canvas.Top="150" />
          <Rectangle Fill="Blue" Width="100" Height="100" Canvas.Left="200" Canvas.Top="150" />
          <Rectangle Fill="Green" Width="100" Height="100" Canvas.Left="350" Canvas.Top="150" />

          <Rectangle Fill="Orange" Width="100" Height="100" Canvas.Left="50" Canvas.Top="300" />
          <Rectangle Fill="Purple" Width="100" Height="100" Canvas.Left="200" Canvas.Top="300" />
          <Rectangle Fill="Cyan" Width="100" Height="100" Canvas.Left="350" Canvas.Top="300" />
        </Canvas>
      </paz:ZoomBorder>
    </Border>

    <!-- Controls -->
    <StackPanel Grid.Column="1" Margin="12" Spacing="8">
      <TextBlock Text="State Serialization" FontWeight="Bold" FontSize="16" />
      <TextBlock Text="Save and restore zoom/pan state" TextWrapping="Wrap" />

      <Separator Margin="0,8" />

      <TextBlock Text="State Controls:" FontWeight="SemiBold" />
      <Button Content="Export State" Click="Export_Click" />
      <Button Content="Import State" Click="Import_Click" />
      <Button Content="Reset State" Click="Reset_Click" />

      <Separator Margin="0,8" />

      <TextBlock Text="State JSON:" FontWeight="SemiBold" />
      <ScrollViewer Height="350" VerticalScrollBarVisibility="Auto">
        <TextBox Text="{Binding StateJson, Mode=OneWay}"
                 IsReadOnly="True"
                 FontFamily="Consolas"
                 FontSize="10"
                 TextWrapping="Wrap"
                 AcceptsReturn="True" />
      </ScrollViewer>
    </StackPanel>
  </Grid>

</UserControl>
