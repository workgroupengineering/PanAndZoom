<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:paz="using:Avalonia.Controls.PanAndZoom"
             xmlns:views="using:AvaloniaDemo.Views"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="640"
             x:Class="AvaloniaDemo.MainView"
             FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter">

  <TabControl>
    <!-- Phase 1: Coordinate Conversion -->
    <TabItem Header="Coordinate Conversion">
      <views:CoordinateConversionView />
    </TabItem>

    <!-- Phase 1: Bounds &amp; Callbacks -->
    <TabItem Header="Bounds &amp; Callbacks">
      <views:BoundsCallbacksView />
    </TabItem>

    <!-- Phase 2: Keyboard &amp; Reset -->
    <TabItem Header="Keyboard &amp; Reset">
      <views:KeyboardResetView />
    </TabItem>

    <!-- Phase 2: Zoom-to-Rectangle -->
    <TabItem Header="Zoom-to-Rectangle">
      <views:ZoomToRectView />
    </TabItem>

    <!-- Phase 3: Inertia &amp; Gestures -->
    <TabItem Header="Inertia &amp; Gestures">
      <views:InertiaGesturesView />
    </TabItem>

    <!-- Phase 3: View History -->
    <TabItem Header="View History">
      <views:ViewHistoryView />
    </TabItem>

    <!-- Phase 4: Dynamic Zoom Limits -->
    <TabItem Header="Dynamic Zoom Limits">
      <views:DynamicZoomLimitsView />
    </TabItem>

    <!-- Phase 4: Grid &amp; Snap -->
    <TabItem Header="Grid &amp; Snap">
      <views:GridSnapView />
    </TabItem>

    <!-- Phase 5: Rotation -->
    <TabItem Header="Rotation">
      <views:RotationView />
    </TabItem>

    <!-- Phase 5: Accessibility -->
    <TabItem Header="Accessibility">
      <views:AccessibilityView />
    </TabItem>

    <!-- Phase 5: State Serialization -->
    <TabItem Header="State Serialization">
      <views:StateSerializationView />
    </TabItem>

    <!-- Original Basic Demos -->
    <TabItem Header="Basic Demo">
      <DockPanel>
        <Panel DockPanel.Dock="Left" Margin="12">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel>
              <StackPanel x:DataType="paz:ZoomBorder" DataContext="{Binding #ZoomBorder1}">
                <StackPanel>
                  <TextBlock Text="PanButton:" />
                  <ComboBox ItemsSource="{x:Static paz:ZoomBorder.ButtonNames}"
                            SelectedItem="{Binding PanButton, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel>
                  <TextBlock Text="Stretch:" />
                  <ComboBox ItemsSource="{x:Static paz:ZoomBorder.StretchModes}"
                            SelectedItem="{Binding Stretch, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel>
                  <TextBlock Text="PowerFactor:" />
                  <TextBox Text="{Binding PowerFactor, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel>
                  <TextBlock Text="ZoomSpeed:" />
                  <TextBox Text="{Binding ZoomSpeed, Mode=TwoWay}" />
                </StackPanel>
                <CheckBox IsChecked="{Binding EnablePan}" Content="EnablePan" />
                <CheckBox IsChecked="{Binding EnableZoom}" Content="EnableZoom" />
                <CheckBox IsChecked="{Binding EnableConstrains}" Content="EnableConstrains" />
                <CheckBox IsChecked="{Binding EnableGestures}" Content="EnableGestures" />
              </StackPanel>
              <StackPanel>
                <TextBlock Text="F - Fill" />
                <TextBlock Text="U - Uniform" />
                <TextBlock Text="R - Reset" />
                <TextBlock Text="T - Toggle Stretch Mode" />
                <TextBlock Text="Mouse Wheel - Zoom to Point" />
                <TextBlock Text="Mouse Left Button Down - Pan" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Panel>
        <Panel DockPanel.Dock="Right" Margin="12">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Width="120" x:DataType="paz:ZoomBorder" DataContext="{Binding #ZoomBorder1}">
              <StackPanel>
                <TextBlock Text="ZoomX:" />
                <TextBlock Text="{Binding ZoomX}" />
              </StackPanel>
              <StackPanel>
                <TextBlock Text="ZoomY:" />
                <TextBlock Text="{Binding ZoomY}" />
              </StackPanel>
              <StackPanel>
                <TextBlock Text="OffsetX:" />
                <TextBlock Text="{Binding OffsetX}" />
              </StackPanel>
              <StackPanel>
                <TextBlock Text="OffsetY:" />
                <TextBlock Text="{Binding OffsetY}" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Panel>
        <Panel Margin="12">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <paz:ZoomBorder x:Name="ZoomBorder1"
                            Stretch="None"
                            ZoomSpeed="1.5"
                            EnableConstrains="False"
                            EnableGestures="True"
                            Background="SlateBlue" ClipToBounds="True" Focusable="True"
                            VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
              <Border Background="Gray" BorderBrush="Yellow" BorderThickness="10">
                <Border.Transitions>
                  <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                  </Transitions>
                </Border.Transitions>
                <Canvas Background="LightGray" Width="300" Height="300">
                  <Rectangle Canvas.Left="125" Canvas.Top="125" Width="50" Height="50" Fill="Red" />
                  <StackPanel Canvas.Left="100" Canvas.Top="200">
                    <TextBlock Text="Text1" Width="100" Background="Red" Foreground="WhiteSmoke" />
                    <TextBlock Text="Text2" Width="100" Background="Red" Foreground="WhiteSmoke" />
                  </StackPanel>
                  <Button Content="Reset Zoom"
                          Command="{Binding ResetMatrix}"
                          x:DataType="paz:ZoomBorder" x:CompileBindings="False"
                          Width="120" Canvas.Left="100" Canvas.Top="250" />
                  <ListBox Width="120"
                           Canvas.Left="10" Canvas.Top="10"
                           x:DataType="paz:ZoomBorder"
                           ItemsSource="{x:Static paz:ZoomBorder.StretchModes}"
                           SelectedItem="{Binding Stretch, Mode=TwoWay}" />
                  <ListBox Width="120"
                           Canvas.Left="160" Canvas.Top="10"
                           x:DataType="paz:ZoomBorder"
                           ItemsSource="{x:Static paz:ZoomBorder.ButtonNames}"
                           SelectedItem="{Binding PanButton, Mode=TwoWay}" />
                </Canvas>
              </Border>
            </paz:ZoomBorder>
          </ScrollViewer>
        </Panel>
      </DockPanel>
    </TabItem>
  </TabControl>

</UserControl>
